{
  "name": "sercherai-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.pc.config.js",
    "dev:pc": "vite --config vite.pc.config.js",
    "dev:h5": "vite --config vite.h5.config.js",
    "build": "vite build --config vite.pc.config.js",
    "build:pc": "vite build --config vite.pc.config.js",
    "build:h5": "vite build --config vite.h5.config.js",
    "build:all": "npm run build:pc && npm run build:h5",
    "preview": "vite preview --config vite.pc.config.js",
    "preview:pc": "vite preview --config vite.pc.config.js",
    "preview:h5": "vite preview --config vite.h5.config.js"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "vue": "^3.5.20",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "vite": "^7.3.1"
  }
}
